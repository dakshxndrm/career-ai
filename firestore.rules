rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user profile is stored at users/{uid}.
    // Only the signed-in user whose uid matches the document id may read or write it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Each user's assessment (questions + answers + result) is stored at
    // assessments/{uid}.  Same ownership check as above.
    match /assessments/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny all access to every other collection or document not matched above.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
