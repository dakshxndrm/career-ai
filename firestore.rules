rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}
    // - Owner can always read/write.
    // - Anyone can read if resource.data.public == true.
    // - Email is never exposed: enforced by app layer (PublicProfile never reads email).
    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid)
                  || resource.data.public == true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // assessments/{uid} — owner-only
    match /assessments/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // roadmapProgress/{uid} — owner-only
    match /roadmapProgress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
