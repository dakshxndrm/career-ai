rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}
    // Owner can always read/write. Anyone can read if public == true.
    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid)
                  || resource.data.public == true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // assessments/{uid}/items/{itemId} — owner-only subcollection
    match /assessments/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // roadmapProgress/{uid}/items/{assessmentId} — owner-only subcollection
    match /roadmapProgress/{uid}/items/{assessmentId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
